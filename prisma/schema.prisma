// NFL Squares - season-long pool
//
// Key design decisions:
//  - Games are GLOBAL (one Game row per NFL game, shared across all Pools).
//  - Auth is via Auth.js (NextAuth v5). Players sign in with Google or
//    username+password. A `User` is the global identity.
//  - When a user joins a pool, a `Participant` row links them to that pool
//    with a per-pool display name + color.
//  - Squares are season-long (a Participant claims a (row, col) once and keeps
//    it all year). Weeks store their own randomized digit headers, so the same
//    physical square represents different digit combinations each week.
//  - Digit headers are stored as 10-char strings of digits 0-9, no repeats.
//    Stored on PoolWeek (not Week), because each pool randomizes independently.
//  - Payments are an append-only ledger of admin-recorded payouts.
//    Winnings are computed on the fly from games + week digits + squares.
//  - First user to sign up becomes admin automatically. Subsequent admin
//    promotions happen through the admin UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Auth (NextAuth v5) -----

model User {
  id            String    @id @default(cuid())
  email         String?   @unique // populated by Google OAuth or optional for credentials
  emailVerified DateTime?
  username      String?   @unique // populated by credentials sign-up
  passwordHash  String?            // bcrypt-hashed; only set for credentials users
  name          String?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts      Account[]
  participants  Participant[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ----- Pool & gameplay -----

model Pool {
  id                  String        @id @default(cuid())
  slug                String        @unique
  name                String
  entryFeePerSquare   Int           // dollars
  weeklyPrize         Int           // dollars to the winning square
  reverseWeeklyPrize  Int           // dollars to the reverse square
  activeWeekNumber    Int           @default(1)
  createdAt           DateTime      @default(now())

  participants  Participant[]
  squares       Square[]
  poolWeeks     PoolWeek[]
  payments      Payment[]
  activity      ActivityLog[]
}

model Participant {
  id        String    @id @default(cuid())
  poolId    String
  userId    String?   // nullable for backwards-compat / admin-created participants
  name      String
  color     String    // hex, e.g. #fecaca
  createdAt DateTime  @default(now())

  pool      Pool      @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  squares   Square[]
  payments  Payment[]

  @@unique([poolId, name])
  @@unique([poolId, userId])
  @@index([userId])
}

model Square {
  id            String   @id @default(cuid())
  poolId        String
  participantId String
  row           Int      // 0-9, fixed for the season
  col           Int      // 0-9, fixed for the season
  createdAt     DateTime @default(now())

  pool          Pool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([poolId, row, col])
  @@index([participantId])
}

model PoolWeek {
  id            String   @id @default(cuid())
  poolId        String
  weekNumber    Int
  rowDigits     String?
  colDigits     String?
  randomizedAt  DateTime?
  createdAt     DateTime @default(now())

  pool          Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, weekNumber])
}

model Game {
  id            String   @id @default(cuid())
  weekNumber    Int
  awayTeam      String
  homeTeam      String
  awayScore     Int?
  homeScore     Int?
  isFinal       Boolean  @default(false)
  kickoffAt     DateTime?
  espnId        String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([weekNumber])
}

model Payment {
  id            String   @id @default(cuid())
  poolId        String
  participantId String
  amount        Int
  note          String?
  paidAt        DateTime @default(now())

  pool          Pool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  poolId    String
  message   String
  createdAt DateTime @default(now())

  pool      Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId, createdAt])
}

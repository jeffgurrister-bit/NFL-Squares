# PostgreSQL connection string. Vercel auto-injects this when you provision
# a Postgres database (Vercel Postgres or Neon) for the project.
# For local dev, use any Postgres instance — a free Neon dev branch is the
# easiest option (https://neon.tech).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Required by NextAuth (Auth.js) to sign session JWTs.
# Generate one with: openssl rand -base64 32
# Vercel may auto-set this if you don't provide it explicitly.
AUTH_SECRET="generate-a-random-string"

# Optional: enables "Sign in with Google". To get these credentials:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth client ID (type: Web application)
#   3. Add your site URL (e.g. https://your-app.vercel.app) under
#      "Authorized JavaScript origins"
#   4. Add https://your-app.vercel.app/api/auth/callback/google under
#      "Authorized redirect URIs"
#   5. Paste the resulting Client ID and Client Secret below
# If left blank, the app falls back to username/password only.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
